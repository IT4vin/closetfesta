# ===============================
# PRODUÇÃO - CLOSETFESTA API
# ===============================

# ===============================
# APLICAÇÃO
# ===============================
NODE_ENV=production
APP_NAME=ClosetFesta API
APP_VERSION=1.0.0
APP_URL=https://api.closetfesta.com

# ===============================
# SERVIDOR
# ===============================
PORT=3001
HOST=0.0.0.0

# ===============================
# DATABASE (PostgreSQL)
# ===============================
DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=closetfesta_prod
DB_USER=closetfesta_user
DB_PASS=CHANGE_THIS_STRONG_PASSWORD_123!

# Pool de Conexões
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_POOL_IDLE=10000
DB_POOL_ACQUIRE=60000

# SSL
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# Logging
DB_LOGGING=false

# ===============================
# CACHE (Redis)
# ===============================
CACHE_ENABLED=true
CACHE_TYPE=redis
CACHE_HOST=redis
CACHE_PORT=6379
CACHE_PASSWORD=CHANGE_THIS_REDIS_PASSWORD_456!
CACHE_DATABASE=0
CACHE_TTL=3600
CACHE_TLS=false

# ===============================
# AUTENTICAÇÃO
# ===============================
JWT_SECRET=CHANGE_THIS_SUPER_SECRET_JWT_KEY_789!
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=CHANGE_THIS_REFRESH_SECRET_ABC!
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# ===============================
# UPLOADS
# ===============================
UPLOAD_ENABLED=true
UPLOAD_MAX_SIZE=10485760
UPLOAD_PATH=/app/uploads
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp
UPLOAD_MAX_FILES=10

# CDN (opcional)
CDN_ENABLED=false
CDN_URL=https://cdn.closetfesta.com
CDN_BUCKET=closetfesta-uploads

# ===============================
# LOGGING
# ===============================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_TIMESTAMP=true
LOG_COLORS=false

# Arquivo
LOG_FILE_ENABLED=true
LOG_FILE_PATH=/app/logs
LOG_FILE_MAX_SIZE=50mb
LOG_FILE_MAX_FILES=10

# HTTP Requests
LOG_HTTP_ENABLED=true
LOG_HTTP_FORMAT=combined

# Database
LOG_DATABASE_ENABLED=false
LOG_DATABASE_SLOW_THRESHOLD=1000

# ===============================
# RATE LIMITING
# ===============================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_MESSAGE=Muitas requisições. Tente novamente em 15 minutos.

# Auth específico
RATE_LIMIT_AUTH_ENABLED=true
RATE_LIMIT_AUTH_WINDOW=900000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_MESSAGE=Muitas tentativas de login. Tente novamente em 15 minutos.

# ===============================
# EMAIL
# ===============================
EMAIL_ENABLED=true
EMAIL_SERVICE=smtp
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=noreply@closetfesta.com
EMAIL_PASS=CHANGE_THIS_EMAIL_PASSWORD_DEF!

# Templates
EMAIL_FROM_NAME=ClosetFesta
EMAIL_FROM_EMAIL=noreply@closetfesta.com

# ===============================
# SEGURANÇA
# ===============================
# CORS
CORS_ENABLED=true
CORS_ORIGIN=https://closetfesta.com,https://www.closetfesta.com
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization

# Headers de Segurança
SECURITY_HELMET_ENABLED=true
SECURITY_COMPRESSION_ENABLED=true
SECURITY_XSS_PROTECTION=true
SECURITY_FRAME_OPTIONS=SAMEORIGIN
SECURITY_CONTENT_TYPE_OPTIONS=true

# API Keys (se necessário)
API_KEY_ENABLED=false
API_KEY_HEADER=X-API-Key

# ===============================
# MONITORING
# ===============================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health

# Métricas
METRICS_ENABLED=true
METRICS_PATH=/metrics
METRICS_COLLECT_DEFAULT=true

# ===============================
# BACKUP
# ===============================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/app/backups

# S3 (opcional)
BACKUP_S3_ENABLED=false
BACKUP_S3_BUCKET=closetfesta-backups
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ACCESS_KEY=YOUR_AWS_ACCESS_KEY
BACKUP_S3_SECRET_KEY=YOUR_AWS_SECRET_KEY

# ===============================
# NOTIFICAÇÕES
# ===============================
# Slack (opcional)
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_CHANNEL=#alerts
SLACK_USERNAME=ClosetFesta Bot

# Discord (opcional)
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/DISCORD/WEBHOOK

# ===============================
# DOCKER COMPOSE
# ===============================
POSTGRES_DB=closetfesta_prod
POSTGRES_USER=closetfesta_user
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_123!

REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD_456!

GRAFANA_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD_789!

# ===============================
# SSL/TLS
# ===============================
SSL_ENABLED=true
SSL_CERT_PATH=/app/ssl/cert.pem
SSL_KEY_PATH=/app/ssl/key.pem

# ===============================
# TIMEZONE
# ===============================
TZ=America/Sao_Paulo 