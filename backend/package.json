{
  "name": "closet-festa-backend",
  "version": "1.0.0",
  "description": "Backend Node.js para o sistema Closet Festa",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "echo 'Build completed'",
    "migrate": "node src/database/migrate.js",
