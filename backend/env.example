# Configuração do Servidor
PORT=3001
NODE_ENV=development

# Banco de Dados (desenvolvimento - SQLite)
DB_TYPE=sqlite
DB_PATH=./data/database.db

# Banco de Dados (produção - PostgreSQL)
# DB_TYPE=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=closet_festa
# DB_USER=postgres
# DB_PASSWORD=your_password

# JWT Secret
JWT_SECRET=sua_chave_super_secreta_aqui_mude_em_producao

# Upload de Imagens
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# CORS
FRONTEND_URL=http://localhost:8084
SHOWCASE_URL=http://localhost:8085

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100 