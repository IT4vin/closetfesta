# ==============================================
# CONFIGURAÇÕES DO SERVIDOR
# ==============================================
NODE_ENV=development
PORT=3001
HOST=localhost

# URLs permitidas pelo CORS (separadas por vírgula)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# ==============================================
# CONFIGURAÇÕES DO BANCO DE DADOS
# ==============================================
DB_TYPE=sqlite
DB_PATH=./data/closet_festa.db

# Para PostgreSQL (descomente e configure se necessário)
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=closet_festa
# DB_USERNAME=postgres
# DB_PASSWORD=senha123
# DB_POOL_MIN=2
# DB_POOL_MAX=10
# DB_LOGGING=false
# DB_SSL=false

# ==============================================
# CONFIGURAÇÕES DE AUTENTICAÇÃO
# ==============================================
JWT_SECRET=closet-festa-super-secret-key-2024-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d
SALT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME=900000

# ==============================================
# CONFIGURAÇÕES DE UPLOAD
# ==============================================
MAX_FILE_SIZE=10485760
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif
UPLOAD_DIR=./uploads
TEMP_DIR=./temp
IMAGE_QUALITY=85
THUMBNAIL_WIDTH=300
THUMBNAIL_HEIGHT=300

# ==============================================
# CONFIGURAÇÕES DE RATE LIMITING
# ==============================================
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=900000

# ==============================================
# CONFIGURAÇÕES DE LOGGING
# ==============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5
LOG_DATE_PATTERN=YYYY-MM-DD
ENABLE_CONSOLE_LOG=true

# ==============================================
# CONFIGURAÇÕES DE EMAIL (FUTURAS)
# ==============================================
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@closetfesta.com

# ==============================================
# CONFIGURAÇÕES DE CACHE (FUTURAS)
# ==============================================
CACHE_TTL=3600
CACHE_MAX=1000
CACHE_ENABLED=false

# ==============================================
# CONFIGURAÇÕES DE BACKUP
# ==============================================
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION=7
BACKUP_PATH=./backups

# ==============================================
# CONFIGURAÇÕES DE SEGURANÇA
# ==============================================
ENABLE_HELMET=true
ENABLE_COMPRESSION=true
ENABLE_HTTPS=false
HTTPS_PORT=443
SSL_CERT=
SSL_KEY=

# ==============================================
# CONFIGURAÇÕES DA APLICAÇÃO
# ==============================================
APP_NAME=Closet Festa
APP_VERSION=1.0.0
APP_DESCRIPTION=Sistema de gerenciamento para loja de roupas
TZ=America/Sao_Paulo
CURRENCY=BRL
LOCALE=pt-BR 