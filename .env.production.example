# ==============================================
# CLOSET FESTA - Variáveis para produção
# ==============================================
# Copie para .env e preencha os valores.
# Use este arquivo com docker-compose.production.yml

# ---------- PostgreSQL ----------
POSTGRES_DB=closet_festa
POSTGRES_USER=closetfesta
POSTGRES_PASSWORD=COLOQUE_SENHA_FORTE_AQUI

# ---------- Redis ----------
REDIS_PASSWORD=COLOQUE_SENHA_REDIS_AQUI

# ---------- JWT (obrigatório: mínimo 32 caracteres) ----------
JWT_SECRET=COLOQUE_UM_SEGREDO_JWT_LONGO_E_ALEATORIO_32_CARACTERES

# ---------- CORS (URLs dos frontends separadas por vírgula) ----------
# Exemplo: https://admin.seudominio.com,https://catalogo.seudominio.com
# CORS_ORIGINS=https://admin.seudominio.com,https://catalogo.seudominio.com

# ---------- Email (opcional; configure se for usar notificações) ----------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ---------- Monitoramento (perfil monitoring) ----------
# GRAFANA_PASSWORD=admin
